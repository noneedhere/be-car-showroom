// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  ADMIN
  CUSTOMER
}

enum Category {
  SPORT
  FAMILY
}

model User {
  id_user        Int      @id @default(autoincrement())
  uuid           String   @unique @default(uuid())
  name           String
  email          String   @unique
  password       String
  profilePicture String   @default("")
  role           Role     @default(CUSTOMER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sales          Sale[]
}

model Car {
  id_car      Int        @id @default(autoincrement())
  uuid        String     @unique @default(uuid())
  name        String
  category    Category   @default(FAMILY)
  year        Int
  price       Int
  image       String?
  description String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  sales       Sale[]
  OrderList   SaleList[]
}

model Sale {
  id_sale     Int        @id @default(autoincrement())
  uuid        String     @unique @default(uuid())
  buyerName   String
  saleDate    DateTime   @default(now())
  car         Car?       @relation(fields: [carId], references: [id_car])
  carId       Int
  user        User       @relation(fields: [userId], references: [id_user])
  userId      Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  total_price Int        @default(0)
  OrderList   SaleList[]
}

model SaleList {
  id_saleList Int      @id @default(autoincrement())
  uuid        String   @unique @default("")
  quantity    Int      @default(0)
  note        String   @default("") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  car         Car?     @relation(fields: [carId], references: [id_car])
  carId       Int?
  sale        Sale?    @relation(fields: [saleId], references: [id_sale])
  saleId      Int?
}
