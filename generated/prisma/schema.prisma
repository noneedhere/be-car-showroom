// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  SALES
}

enum Category {
  SPORT
  FAMILY
}

model User {
  id_user        Int      @id @default(autoincrement())
  uuid           String   @unique @default(uuid())
  name           String
  email          String   @unique
  password       String
  profilePicture String   @default("")
  role           Role     @default(MANAGER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sales          Sale[]
}

model Car {
  id_car      Int      @id @default(autoincrement())
  uuid        String   @unique @default(uuid())
  name       String
  categoty    Category @default(FAMILY)
  // year        Int
  price       Int
  // stock       Int      @default(0)
  image       String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sales       Sale[]
}

model Sale {
  id_sale   Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid())
  buyerName String
  saleDate  DateTime @default(now())
  car       Car?     @relation(fields: [carId], references: [id_car])
  carId     Int
  user      User     @relation(fields: [userId], references: [id_user])
  userId    Int
  price     Int
}
